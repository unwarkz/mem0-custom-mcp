# URL of your self-hosted Mem0 API instance
MEM0_API_URL=http://localhost:8888

# Default user ID for memory operations
DEFAULT_USER_ID=default

# Port the MCP HTTP server listens on (default: 3000)
MCP_PORT=3000

# Bearer token sent as "Authorization: Bearer <token>" on every request to the mem0 API.
# Leave unset (or empty) to make unauthenticated requests.
# MEM0_BEARER_TOKEN=

# Token that MCP clients must supply as "Authorization: Bearer <token>" in every HTTP request.
# Leave unset (or empty) to disable client authentication.
# MCP_AUTH_TOKEN=
